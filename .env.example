# Docker Configuration
COMPOSE_PROJECT_NAME=vector-obfuscation-with-csfle

# MongoDB Atlas Local Configuration
MONGO_PORT=27017
MONGO_URI=mongodb://mongo-local:27017
MONGO_VAULT_NAMESPACE=encryption_vault.keyVault

# Cryptography (CSFLE)
# This 96-byte key will be automatically generated and injected by 'make init'
LOCAL_MASTER_KEY=

# Spring Boot 3.5 Backend Configuration
BACKEND_PORT=8080

# Next.js Frontend Configuration
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080
# Next.js Telemetry (Must be 1 to disable, 0 or empty to enable)
# We set this to 1 to prevent the container from attempting to reach the internet.
NEXT_TELEMETRY_DISABLED=1